{
  "name": "stu-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo Nx para apps web y mobile de STU",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "start": "nx run-many --target=serve --all",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all"
  },
  "devDependencies": {
    "nx": "^21.0.0",
    "typescript": "^5.6.0"
  }
}
